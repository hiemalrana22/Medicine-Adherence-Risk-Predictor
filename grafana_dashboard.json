      "type": "barchart",
      "title": "Adherence Rate by Age Group",
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "medical-sqlite"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT age_group_label AS group_name, ROUND(AVG(actual_adherence) * 100.0, 2) AS adherence_rate FROM final_predictions GROUP BY age_group_label ORDER BY adherence_rate DESC;"
        }
      ],
      "options": {
        "orientation": "auto",
