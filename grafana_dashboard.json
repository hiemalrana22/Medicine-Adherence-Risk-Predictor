        "overrides": []
      }
    },
    {
      "type": "barchart",
      "title": "Adherence Rate by Insurance Type",
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "medical-sqlite"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT insurance_type, ROUND(AVG(actual_adherence) * 100.0, 2) AS adherence_rate FROM final_predictions GROUP BY insurance_type ORDER BY adherence_rate DESC;"
        }
      ],
      "options": {
        "orientation": "auto",
        "showValue": "auto",
        "stacking": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "type": "barchart",
      "title": "Prediction Confidence Distribution",
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "medical-sqlite"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT confidence, COUNT(*) AS patients FROM final_predictions GROUP BY confidence ORDER BY CASE confidence WHEN 'High' THEN 1 WHEN 'Medium' THEN 2 ELSE 3 END;"
        }
      ],
      "options": {
        "orientation": "auto",
        "showValue": "auto",
        "stacking": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "type": "barchart",
      "title": "Confusion Matrix Components",
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "medical-sqlite"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT 'TP' AS metric, SUM(CASE WHEN actual_adherence = 1 AND predicted_adherence = 1 THEN 1 ELSE 0 END) AS value FROM final_predictions UNION ALL SELECT 'TN' AS metric, SUM(CASE WHEN actual_adherence = 0 AND predicted_adherence = 0 THEN 1 ELSE 0 END) AS value FROM final_predictions UNION ALL SELECT 'FP' AS metric, SUM(CASE WHEN actual_adherence = 0 AND predicted_adherence = 1 THEN 1 ELSE 0 END) AS value FROM final_predictions UNION ALL SELECT 'FN' AS metric, SUM(CASE WHEN actual_adherence = 1 AND predicted_adherence = 0 THEN 1 ELSE 0 END) AS value FROM final_predictions;"
        }
      ],
      "options": {
        "orientation": "auto",
        "showValue": "auto",
        "stacking": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "type": "table",
      "title": "Model Metrics Comparison",
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "medical-sqlite"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT model, ROUND(accuracy * 100.0, 2) AS accuracy_pct, precision, recall, f1_score, roc_auc FROM model_metrics ORDER BY roc_auc DESC;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
